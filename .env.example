NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_APP_BASE_URL=http://localhost:3791
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws
NEXT_PUBLIC_BUBLI_PREVIEW_DATA=false
NEXT_PUBLIC_TAURI_APP_URL=https://app.bubli.kr/app

# 새 UI Kit 대시보드 전환 플래그(1차 라우트 적용). true면 /app이 DashboardView로 뜬다.
# 미설정/false면 기존 대시보드 화면이 그대로 유지된다. 문제 시 끄면 즉시 복귀.
NEXT_PUBLIC_BUBLI_NEW_DASHBOARD=false

# 새 UI Kit 자료 흐름 전환 플래그. true면 /app/resources가 ResourceFlowView로 뜬다.
# 미설정/false면 기존 자료보드 화면이 그대로 유지된다.
NEXT_PUBLIC_BUBLI_NEW_RESOURCES=false

# 새 UI Kit 위젯 미리보기 전환 플래그. true면 /app/desktop/widgets가 WidgetPreview 4상태로 뜬다.
# 미설정/false면 기존 데스크톱 위젯 랩 화면이 그대로 유지된다. 실제 Tauri 창 제어는 없다.
NEXT_PUBLIC_BUBLI_NEW_WIDGET_PREVIEW=false
