{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Bubli",
  "version": "0.1.0",
  "identifier": "kr.bubli.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../.next"
  },
  "app": {
    "windows": [
      {
        "title": "Bubli",
        "width": 1280,
        "height": 820,
        "url": "/app"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
