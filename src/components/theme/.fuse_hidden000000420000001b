import { useState } from "react";
import type { Meta, StoryObj } from "@storybook/nextjs-vite";

import { ThemeProvider, ThemeToggle, useTheme } from "@/components/theme";
import type { Theme } from "@/components/theme";
import { Button } from "@/components/ui/button";
import { Chip } from "@/components/ui/chip";
import { GlassPanel } from "@/components/ui/glass-panel";
import { StatusBadge } from "@/components/ui/status-badge";

const meta = {
  title: "Theme/ThemeProvider",
  parameters: {
    docs: {
      description: {
        component:
          "라이트/다크/시스템을 ThemeProvider로 연결. 토글을 누르면 data-theme이 바뀌고 기존 컴포넌트가 변수 기반으로 반응한다. 스토리는 격리를 위해 미리보기 박스에만 attribute를 적용하고 localStorage는 끈다.",
      },
    },
  },
} satisfies Meta;

export default meta;
type Story = StoryObj;

function Sample() {
  const { theme, resolvedTheme } = useTheme();
  return (
    <div style={{ display: "grid", gap: 16 }}>
      <div style={{ display: "flex", alignItems: "center", justifyContent: "space-between", gap: 16 }}>
        <ThemeToggle />
        <span style={{ fontSize: 12, color: "var(--text-faint, #98A5AF)" }}>
          theme: {theme} · resolved: {resolvedTheme}
        </span>
      </div>
      <GlassPanel>
        <div style={{ display: "grid", gap: 12, padding: 4 }}>
          <strong style={{ fontSize: 14 }}>오늘 할 일</strong>
          <p style={{ fontSize: 13, margin: 0, color: "var(--text-soft, #586978)" }}>
            시안 1차 보내기 · 견적서 회신 확인
          </p>
          <div style={{ display: "flex", gap: 8, flexWrap: "wrap" }}>
            <Chip selected>진행중</Chip>
            <StatusBadge tone="warning">예정</StatusBadge>
            <StatusBadge tone="approved">승인</StatusBadge>
          </div>
          <div style={{ display: "flex", gap: 8 }}>
            <Button variant="primary">확인</Button>
            <Button>취소</Button>
          </div>
        </div>
      </GlassPanel>
    </div>
  );
}

/** 미리보기 박스에만 data-theme을 붙여 Storybook 전역을 오염시키지 않는다. */
function Preview({ defaultTheme }: { defaultTheme?: Theme }) {
  const [el, setEl] = useState<HTMLDivElement | null>(null);
  return (
    <div
      ref={setEl}
      style={{
        borderRadius: 22,
        padding: 24,
        width: 460,
        background: defaultTheme === "dark" ? "#161E2E" : "#FCFDFF",
        transition: "background 200ms ease",
      }}
    >
      {el ? (
        <ThemeProvider attributeTarget={el} defaultTheme={defaultTheme} enableStorage={false}>
          <Sample />
        </ThemeProvider>
      ) : null}
    </div>
  );
}

export const Light: Story = { render: () => <Preview defaultTheme="light" /> };
export const Dark: Story = { render: () => <Preview defaultTheme="dark" /> };
export const System: Story = {
  parameters: {
    docs: { description: { story: "system은 OS 선호(prefers-color-scheme)를 따라간다. 토글로 직접 바꿀 수도 있다." } },
  },
  render: () => <Preview defaultTheme="system" />,
};

export const ToggleOnly: Story = {
  render: function ToggleOnlyStory() {
    const [el, setEl] = useState<HTMLDivElement | null>(null);
    return (
      <div ref={setEl} style={{ padding: 16 }}>
        {el ? (
          <ThemeProvider attributeTarget={el} defaultTheme="light" enableStorage={false}>
            <div style={{ display: "flex", gap: 24, alignItems: "center" }}>
              <ThemeToggle />
              <ThemeToggle compact />
            </div>
          </ThemeProvider>
        ) : null}
      </div>
    );
  },
};
